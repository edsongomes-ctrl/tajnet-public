# Copier vers .env — daemons IPFS + Tajcoin sur l'hôte (Linux)
# Guide utilisateur : README.md — Référence technique : docs/REFERENCE-API.md

# full = opérateur (Super CV, Matomo, Futuremen) · public = naissance officielle (Bran Web)
TAJNET_EDITION=public

MATOMO_DB_PASSWORD=changeme
MATOMO_DB_USER=matomo
MATOMO_DB_NAME=matomo

# Dossier Tajcoin sur votre machine (wallet.dat, tajcoin.conf — addnode P2P)
TAJCOIN_HOST_DATADIR=/home/USER/.tajcoin
# TAJCOIN_CONF_FILE=/chemin/explicite/tajcoin.conf

# Données persistantes du nœud (Discover, pins, Super CV) — monté en Docker sur ./data
# TAJNET_DATA_DIR=/chemin/vers/data

# Bootstrap Tajcoin (~530 Mo, hors dépôt Git) — release Taj-Coin/tajcoin
# TAJCOIN_BOOTSTRAP_URL=https://github.com/Taj-Coin/tajcoin/releases/download/v1.1/bootstrap-900600.zip

# ─── Panel & services web ───
PANEL_PORT=8090

# HTTPS (certificat auto-signé SHA-256) — génération : ./scripts/generate-tls-cert.sh
# TLS_ENABLED=true
# TLS_PORT=8443
# TLS_CERT_FILE=./data/tls/cert.pem
# TLS_KEY_FILE=./data/tls/key.pem
# TLS_HTTP_REDIRECT=true
# TLS_HTTP_ALSO=false
# TLS_CN=localhost
# TLS_SAN=DNS:localhost,DNS:mon.domaine,IP:127.0.0.1,IP:192.168.1.76
# Sans nom de domaine (VPS par IP) : certificat auto-signé — uploads WAN possibles en Failed to fetch
# tant qu'un domaine + Let's Encrypt n'est pas configuré (voir README § Sans nom de domaine)
# Empreinte SHA-256 affichée au démarrage et dans GET /api/status → tls.fingerprintSha256

IPFS_API_URL=http://127.0.0.1:5001
IPFS_GATEWAY_URL=http://127.0.0.1:8080
# Gateway public pour les clients sans nœud IPFS (dweb.link par défaut)
# IPFS_GATEWAY_PUBLIC_URL=https://dweb.link
IPFS_MAX_UPLOAD_MB=100
TAJCOIN_RPC_URL=http://127.0.0.1:12107
MATOMO_URL=http://127.0.0.1:8888
MATOMO_SITE_ID=1
# Port localhost du conteneur Matomo (bind 127.0.0.1 — VPS : souvent 8877 si 8888 occupé)
# Conservé entre deploys par deploy-vps.sh — adapter le tunnel SSH si vous changez ce port
# MATOMO_HOST_PORT=8877

# Compte Tajcoin pour les paiements automatiques du panel (Guard, Pin, annonces)
TAJNET_WALLET_ACCOUNT=tajpanel

# Wallet nœud : par défaut localhost uniquement (sécurité LAN/WAN). Dev LAN uniquement :
# WALLET_LOCAL_LAN=true

# Panel / wallet / éditeur sur Internet (nœud public) — désactivé par défaut.
# Mode VPS recommandé : page d'accueil publique + panel WAN avec MetaMask obligatoire.
# TAJNODE_MODE=vps
# PUBLIC_PANEL=true   # alias de TAJNODE_MODE=vps
# Admin distant sans exposition WAN : tunnel SSH -L 8090:127.0.0.1:8090 user@serveur
# WAN_PANEL_ACCESS=true   # panel sur WAN — Matomo reste localhost/LAN uniquement

# Derrière reverse proxy (Nginx/Caddy) — pour détecter l'IP client réelle :
# TRUST_PROXY=1

# RPC public (optionnel — profil « Nœud public » dans le wallet MetaMask)
# TAJCOIN_PUBLIC_RPC_URL=http://rpc.example.com:12107
# TAJCOIN_PUBLIC_RPC_USER=tajcoinrpc
# TAJCOIN_PUBLIC_RPC_PASSWORD=

# URL Matomo visible depuis les pages IPFS / Futuremen (sinon = MATOMO_URL interne)
# Sur VPS : https://votre-domaine/matomo — défini par deploy-vps.sh / enable-vps-domain.sh
# Repli automatique : {DISCOVER_NODE_ENDPOINT}/matomo/
# MATOMO_PUBLIC_URL=https://tajnet.cloud/matomo

# Auth RPC Tajcoin — obligatoire en mode embarqué ou Docker externe
TAJCOIN_RPC_USER=tajnet
TAJCOIN_RPC_PASSWORD=changeme
# TAJCOIN_COOKIE_FILE=   # laisser vide si auth user/password

# ─── Guard — sas d'accès avant upload/publish/CV ───
GUARD_PRICE_TAJ=1
GUARD_MIN_CONFIRMATIONS=1
GUARD_SESSION_TTL_MS=3600000
GUARD_PAYMENT_TIMEOUT_MS=900000
GUARD_POLL_MS=12000
GUARD_ACCOUNT=tajguard
# GUARD_PAYMENT_ADDRESS=   # adresse fixe optionnelle
# GUARD_BYPASS=true        # tests locaux uniquement — désactive le paywall

# ─── Annonces blockchain (OP_RETURN + metadata IPFS) ───
ANNOUNCE_ENABLED=true
ANNOUNCE_ACCOUNT=tajannounce
ANNOUNCE_FUND_TAJ=1
# ANNOUNCE_WALLET_PASSPHRASE=   # si wallet Tajcoin chiffré
# TAJCOIN_WALLET_PASSPHRASE=    # alias accepté

# ─── Discover — index des contenus publiés ───
# false en local par défaut ; deploy-vps.sh force true sur les nœuds publics
DISCOVER_ENABLED=false
DISCOVER_SCAN_INTERVAL_MS=60000
DISCOVER_BLOCKS_PER_SCAN=120
DISCOVER_LOOKBACK_BLOCKS=5000
DISCOVER_FETCH_METADATA=true
DISCOVER_WALLET_SCAN=true
DISCOVER_WALLET_TX_LIMIT=5000

# ─── Pinning payant & récompenses lecteur / split ───
PIN_SERVICE_ENABLED=true
PIN_ACCOUNT=tajpin
PIN_MIN_CONFIRMATIONS=1
# Répartition à chaque réclamation (total = PIN_REWARD_PER_CLAIM, défaut 0.5 TAJ)
# PIN_REWARD_PER_CLAIM=0.5
# REWARD_SPLIT_CREATOR=0.25
# REWARD_SPLIT_CONTRIBUTOR=0.25  # alias legacy de REWARD_SPLIT_CREATOR
# REWARD_SPLIT_READER=0.25
# REWARD_SPLIT_HOST=0.25
# REWARD_SPLIT_INVESTOR=0.25
# HOST_REWARD_ACCOUNT=tajpanel
PIN_REWARD_AUTO_PAY=true
REWARD_ESCROW_ACCOUNT=tajescrow
ANNOUNCE_PIN_REWARD_TAJ=0.5
# DISCOVER_NODE_NAME=Mon TajNode
# DISCOVER_NODE_ENDPOINT=https://tajnet.cloud
# FUTUREMEN_NODE_URLS=https://tajnet.cloud|São Paulo,http://127.0.0.1:8090|localhost
# FUTUREMEN_PUBLIC_ORIGIN=https://tajnet.cloud
# DISCOVER_PIN_PRICE_TAJ=0.5

# ─── Super CV — consultation recruteur (paywall IPFS) ───
# S'applique à /cv, Discover (type cv) et /view — voir core/lib/cv-discover-gate.js
# CV_ACCESS_ENABLED=true
# CV_ACCESS_PRICE_TAJ=1
# CV_ACCESS_ACCOUNT=tajcv
# CV_ACCESS_MIN_CONFIRMATIONS=1
# CV_ACCESS_PAYMENT_TIMEOUT_MS=1800000
# CV_ACCESS_POLL_MS=12000

# ─── Bran Web — publication HTML IPFS + Tajcoin ───
# Éditeur client : /bran-web/edit.html (gratuit) · publish : 2 TAJ + MetaMask
# Archive démo opérateur : POST /api/bran-web/generate (Python 3 dans image Docker core)
# BRAN_PUBLISH_ENABLED=true
# BRAN_PUBLISH_PRICE_TAJ=2
# BRAN_PUBLISH_ACCOUNT=tajbran
# BRAN_PUBLISH_MIN_CONFIRMATIONS=1
